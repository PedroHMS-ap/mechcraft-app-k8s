{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "nest start",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:full": "npm audit",
    "audit:report": "npm audit --omit=dev --json > audit-report.json || exit 0",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "test": "jest -c jest.config.js",
    "test:cov": "jest --coverage -c jest.config.js",
    "prisma:pull": "prisma db pull && prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "seed": "node dist/prisma/seed.js",
    "postinstall": "prisma generate",
    "start:prod": "node -r newrelic dist/main.js",
    "test:e2e": "jest -c jest-e2e.config.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.20",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^6.18.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cpf-cnpj-validator": "^1.0.3",
    "newrelic": "^13.17.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.20",
    "@types/jest": "^29.5.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "prisma": "^6.18.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "validator": "^13.15.20",
    "class-validator": "^0.14.1"
  }
}
