{
  "name": "MechCraft Observability",
  "permissions": "PUBLIC_READ_ONLY",
  "pages": [
    {
      "name": "Plataforma",
      "widgets": [
        {
          "title": "Latencia p95 por rota",
          "layout": { "column": 1, "row": 1, "width": 6, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [0],
                "query": "FROM Transaction SELECT percentile(duration, 95) FACET path TIMESERIES 1 minute WHERE appName = 'mechcraft-api'"
              }
            ]
          }
        },
        {
          "title": "Healthchecks e uptime",
          "layout": { "column": 7, "row": 1, "width": 6, "height": 3 },
          "visualization": { "id": "viz.billboard" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [0],
                "query": "FROM HealthCheckResult SELECT percentage(count(*), WHERE isHealthy = true) FACET checkType SINCE 30 minutes ago"
              }
            ]
          }
        },
        {
          "title": "CPU media por pod",
          "layout": { "column": 1, "row": 4, "width": 6, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [0],
                "query": "FROM K8sContainerSample SELECT average(cpuUsedCores) FACET podName TIMESERIES WHERE clusterName = 'mechcraft-aks' AND podName LIKE 'mechcraft-api-%'"
              }
            ]
          }
        },
        {
          "title": "Memoria media por pod",
          "layout": { "column": 7, "row": 4, "width": 6, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [0],
                "query": "FROM K8sContainerSample SELECT average(memoryWorkingSetBytes / 1048576) FACET podName TIMESERIES WHERE clusterName = 'mechcraft-aks' AND podName LIKE 'mechcraft-api-%'"
              }
            ]
          }
        },
        {
          "title": "Falhas HTTP e processamento de OS",
          "layout": { "column": 1, "row": 7, "width": 12, "height": 3 },
          "visualization": { "id": "viz.table" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [0],
                "query": "FROM WorkOrderProcessingFailure SELECT count(*) FACET failureType, path SINCE 24 hours ago LIMIT 50"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Negocio",
      "widgets": [
        {
          "title": "Volume diario de ordens de servico",
          "layout": { "column": 1, "row": 1, "width": 4, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [0],
                "query": "FROM WorkOrderCreated SELECT count(*) TIMESERIES 1 day SINCE 30 days ago"
              }
            ]
          }
        },
        {
          "title": "Tempo medio por etapa",
          "layout": { "column": 5, "row": 1, "width": 4, "height": 3 },
          "visualization": { "id": "viz.bar" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [0],
                "query": "FROM WorkOrderStageDuration SELECT average(durationHours) FACET stage SINCE 30 days ago"
              }
            ]
          }
        },
        {
          "title": "Falhas de integracao",
          "layout": { "column": 9, "row": 1, "width": 4, "height": 3 },
          "visualization": { "id": "viz.line" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [0],
                "query": "FROM WorkOrderIntegrationFailure SELECT count(*) FACET channel, failureType TIMESERIES 1 hour SINCE 24 hours ago"
              }
            ]
          }
        },
        {
          "title": "Transicoes de status",
          "layout": { "column": 1, "row": 4, "width": 6, "height": 3 },
          "visualization": { "id": "viz.area" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [0],
                "query": "FROM WorkOrderStatusChanged SELECT count(*) FACET toStatus TIMESERIES 1 hour SINCE 7 days ago"
              }
            ]
          }
        },
        {
          "title": "Integracoes processadas",
          "layout": { "column": 7, "row": 4, "width": 6, "height": 3 },
          "visualization": { "id": "viz.table" },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [0],
                "query": "FROM WorkOrderIntegrationProcessed SELECT count(*) FACET channel, flow, action, resultStatus SINCE 24 hours ago"
              }
            ]
          }
        }
      ]
    }
  ]
}
