{
  "name": "MechCraft Operations Dashboard",
  "permissions": "PUBLIC_READ_ONLY",
  "pages": [
    {
      "name": "Plataforma",
      "widgets": [
        {
          "title": "Pods prontos por deployment",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [
                  0
                ],
                "query": "FROM K8sDeploymentSample SELECT latest(podsAvailable) FACET deploymentName WHERE clusterName = 'mechcraft-aks'"
              }
            ]
          }
        },
        {
          "title": "CPU media por pod",
          "layout": {
            "column": 7,
            "row": 1,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [
                  0
                ],
                "query": "FROM K8sContainerSample SELECT average(cpuUsedCores) FACET podName TIMESERIES WHERE clusterName = 'mechcraft-aks' AND podName LIKE 'mechcraft-api-%'"
              }
            ]
          }
        },
        {
          "title": "Memoria media por pod",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [
                  0
                ],
                "query": "FROM K8sContainerSample SELECT average(memoryWorkingSetBytes / 1048576) FACET podName TIMESERIES WHERE clusterName = 'mechcraft-aks' AND podName LIKE 'mechcraft-api-%'"
              }
            ]
          }
        },
        {
          "title": "Eventos do cluster",
          "layout": {
            "column": 7,
            "row": 4,
            "width": 6,
            "height": 3
          },
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountIds": [
                  0
                ],
                "query": "FROM K8sEventSample SELECT latest(message) FACET involvedObjectName, reason WHERE clusterName = 'mechcraft-aks' LIMIT 20"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "APIs e Negocio",
      "widgets": [
        {
          "title": "Volume diario de OS",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "Consumir `GET /metrics/daily-volume` pelo gateway e publicar o resultado como dashboard operacional durante a demonstracao."
          }
        },
        {
          "title": "Tempo medio por status",
          "layout": {
            "column": 5,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "Consumir `GET /metrics/avg-time-by-status` para mostrar diagnostico, execucao e finalizacao."
          }
        },
        {
          "title": "Falhas de integracao",
          "layout": {
            "column": 9,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "Consumir `GET /metrics/integration-errors` para acompanhar erros de webhooks e notificacoes."
          }
        },
        {
          "title": "Latencia e healthchecks",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 12,
            "height": 3
          },
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "Os logs estruturados JSON da API incluem `requestId`, `path`, `statusCode` e `durationMs`. Acompanhar junto com `GET /health` e `GET /health/ready`."
          }
        }
      ]
    }
  ]
}
