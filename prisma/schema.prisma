generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id         Int         @id @default(autoincrement())
  name       String
  document   String?     @unique
  active     Boolean     @default(true)
  phone      String?
  email      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  vehicles   Vehicle[]
  workOrders WorkOrder[]
}

model Vehicle {
  id         Int         @id @default(autoincrement())
  plate      String      @unique
  make       String
  model      String
  year       Int?
  customerId Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrders WorkOrder[]

  @@index([customerId])
}

model WorkOrder {
  id            Int              @id @default(autoincrement())
  customerId    Int
  vehicleId     Int
  description   String
  status        WorkOrderStatus  @default(RECEIVED)

  subtotalServices Decimal @db.Decimal(10,2) @default(0)
  subtotalParts    Decimal @db.Decimal(10,2) @default(0)
  discount         Decimal @db.Decimal(10,2) @default(0)
  total            Decimal @db.Decimal(10,2) @default(0)

  publicCode    String           @unique @default(uuid())
  estimateSentAt DateTime?
  estimateSentBy String?
  approvedAt    DateTime?
  deniedAt      DateTime?
  denialReason  String?
  deniedBy      String?
  approvedBy    String?

  startedAt        DateTime?        // início efetivo da execução
  finishedAt       DateTime?        // quando foi finalizada
  deliveredAt      DateTime?        // entrega ao cliente

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customer      Customer  @relation(fields: [customerId], references: [id])
  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id])

  services      WorkOrderService[]
  parts         WorkOrderPart[]

  @@index([customerId])
  @@index([vehicleId])
}

enum WorkOrderStatus {
  RECEIVED
  DIAGNOSING
  WAITING_APPROVAL
  IN_PROGRESS
  FINISHED
  DELIVERED
}

model ServiceCatalog {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  unitPrice   Decimal  @db.Decimal(10,2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workItems   WorkOrderService[]
}

model Part {
  id          Int      @id @default(autoincrement())
  sku         String   @unique
  name        String
  unitCost    Decimal  @db.Decimal(10,2) // custo (opcional para margem)
  unitPrice   Decimal  @db.Decimal(10,2) // preço de venda
  stockQty    Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workItems   WorkOrderPart[]
}

model WorkOrderService {
  id            Int      @id @default(autoincrement())
  workOrderId   Int
  serviceId     Int
  qty           Int      @default(1)
  unitPrice     Decimal  @db.Decimal(10,2) // snapshot do preço no momento do orçamento
  total         Decimal  @db.Decimal(10,2)
  createdAt    DateTime   @default(now()) 

  workOrder     WorkOrder      @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  service       ServiceCatalog @relation(fields: [serviceId], references: [id])

  @@index([workOrderId])
  @@index([serviceId])
}

model WorkOrderPart {
  id            Int      @id @default(autoincrement())
  workOrderId   Int
  partId        Int
  qty           Int      @default(1)
  unitPrice     Decimal  @db.Decimal(10,2) // snapshot de venda
  total         Decimal  @db.Decimal(10,2)
  createdAt    DateTime   @default(now())

  workOrder     WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  part          Part      @relation(fields: [partId], references: [id])

  @@index([workOrderId])
  @@index([partId])
}
