apiVersion: v1
kind: Secret
metadata:
  name: mechcraft-secrets
  namespace: mechcraft
type: Opaque
stringData:
  # EXAMPLE values. Do NOT commit real secrets. Create secrets with kubectl or your secret manager.
  DATABASE_URL: "postgresql://mech:secret@postgres:5432/mechcraft"
  POSTGRES_PASSWORD: "secret"
  JWT_SECRET: "replace-with-real-jwt-secret"
  EXTERNAL_SERVICE_TOKEN: "replace-with-external-service-token"

# Recommended command to create secret safely (PowerShell):
# kubectl create secret generic mechcraft-secrets -n mechcraft \
#   --from-literal=DATABASE_URL='postgresql://mech:pass@host:5432/mechcraft' \
#   --from-literal=POSTGRES_PASSWORD='pass' \
#   --from-literal=JWT_SECRET='your-jwt-secret' \
#   --from-literal=EXTERNAL_SERVICE_TOKEN='token-value'
