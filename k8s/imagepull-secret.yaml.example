apiVersion: v1
kind: Secret
metadata:
  name: regcred
  namespace: mechcraft
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: "<BASE64_DOCKERCONFIGJSON>" # prefer usar `kubectl create secret docker-registry` ao invés de aplicar este arquivo

# Recomenda-se criar este secret com o comando abaixo (não commitando tokens):
# kubectl create secret docker-registry regcred -n mechcraft \
#   --docker-server=https://index.docker.io/v1/ \
#   --docker-username=pedrooohms \
#   --docker-password=<DOCKERHUB_TOKEN> \
#   --docker-email=you@example.com
